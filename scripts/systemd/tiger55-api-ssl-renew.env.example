# Copy to /etc/default/tiger55-api-ssl-renew and edit values.
# Required for first certificate issuance:
CERTBOT_EMAIL=admin@tiger55.online

# Optional overrides:
API_DOMAIN=api.tiger55.online
CERTBOT_STAGING=0
DRY_RUN=0
# APPLY_SCRIPT can be overridden if needed.
# APPLY_SCRIPT=scripts/apply-nginx-api-config.sh
